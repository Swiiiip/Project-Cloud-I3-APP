# Copy and rename to .env for local run

# Service discovery
GAME_ENGINE_SERVICE_BASE_URL=http://localhost:8010
EMOJI_CATALOG_SERVICE_BASE_URL=http://localhost:8020
EMOJI_RENDER_SERVICE_BASE_URL=http://localhost:8030
API_BASE_URL=http://localhost:8000

# Challenge storage (game_engine only)
# file | game_state_storage | in_memory
CHALLENGE_STORAGE_BACKEND=file

# Gateway session signing (gateway only)
SESSION_COOKIE_SECRET=local-dev-secret
